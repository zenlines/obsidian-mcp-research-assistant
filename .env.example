# TaskNotes HTTP API — local development
TASKNOTES_API_URL=http://localhost:8080
TASKNOTES_API_TOKEN=replace-with-your-real-token

# Vault path — only used for filesystem fallback (project-note search).
# Use forward slashes or escaped backslashes on Windows.
TASKNOTES_VAULT_PATH=path_to_your/obsidian_vault

# --- Future: remote deployment knobs (unused for now) ---
# When deploying behind a tunnel or on a server:
# TASKNOTES_API_URL=https://your-tunnel.example.com
# TASKNOTES_API_TOKEN=<long-random-token>
# TASKNOTES_REQUEST_TIMEOUT=30
